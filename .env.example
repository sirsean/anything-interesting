# Copy to `.env` (gitignored) for local operator commands — do not commit real values.
# Used by: `npm run discord:register-topnews` (see AGENTS.md).

# Same value as `DISCORD_APPLICATION_ID` in wrangler.toml [vars] (public, not a secret).
DISCORD_APPLICATION_ID=
DISCORD_BOT_TOKEN=

# Worker secret for forced Polymarket watchlist refresh: `wrangler secret put OPS_TOKEN`
OPS_TOKEN=

# Production Worker (M5): optional `wrangler secret put DISCORD_BOT_TOKEN` so the hourly
# job can poll 👍/👎 on digest messages and update `source_weights`. Same token as here;
# the Worker never uses it for slash registration, only Discord REST from the edge.
