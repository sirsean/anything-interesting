{
  "name": "anything-interesting",
  "version": "1.0.0",
  "description": "News alerting agent (Cloudflare Workers)",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "wrangler:dev": "wrangler dev",
    "deploy": "vite build && wrangler deploy -c dist/anything_interesting/wrangler.json",
    "check": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.web.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:local": "wrangler d1 migrations apply anything-interesting --local",
    "db:reset-local": "wrangler d1 execute anything-interesting --local --file scripts/reset-local-d1.sql",
    "db:remote": "wrangler d1 migrations apply anything-interesting --remote",
    "discord:register-topnews": "node scripts/register-topnews.mjs"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "fast-xml-parser": "^5.7.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.36.3",
    "@cloudflare/workers-types": "^4.20260510.1",
    "@types/node": "^25.6.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "dotenv": "^17.4.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.11",
    "vitest": "^4.1.5",
    "wrangler": "^4.90.0"
  }
}
